[project]
name = "{{ project_name }}"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = [
    "deepagents>=0.0.10",
    "langchain>=0.3",
    "langchain-anthropic>=0.2",
    "langgraph>=0.2",
    "langsmith>=0.1",
    "fastapi>=0.110",
    "uvicorn>=0.30",
    "python-dotenv>=1.0",
]

[project.optional-dependencies]
dev = ["pytest>=8.0", "ruff>=0.5", "mypy>=1.10"]

[tool.setuptools.packages.find]
include = ["agent*", "evals*", "server*"]
